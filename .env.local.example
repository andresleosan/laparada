# Admin Settings - Never commit secrets to GitHub!
# Copy this file to .env.local and update with your values

# Initial Admin PIN (6 digits)
# IMPORTANTE: Este PIN se convertirá a hash en la BD. Nunca se almacena en texto plano.
# Solo cambiable a través de la página de Configuración de Administrador
VITE_ADMIN_PIN_INITIAL=140492

# Firebase Configuration (get from Firebase Console > Project Settings)
# Public keys are safe to expose, secrets should be in .env.local
VITE_FIREBASE_API_KEY=<your-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<your-auth-domain>
VITE_FIREBASE_PROJECT_ID=<your-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<your-storage-bucket>
VITE_FIREBASE_MESSAGING_SENDER_ID=<your-messaging-sender-id>
VITE_FIREBASE_APP_ID=<your-app-id>
