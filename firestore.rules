rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: verificar si el usuario está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Helper: verificar si el usuario es propietario del documento
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ============ COLECCIÓN: productos ============
    // Productos: cualquiera lee (menú público), solo admin escribe
    match /productos/{productoId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: combos ============
    // Combos: cualquiera lee (menú público), solo admin escribe
    match /combos/{comboId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: ventas ============
    // Ventas: solo admin escribe, solo admin lee (datos financieros)
    match /ventas/{ventaId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: domicilios ============
    // Domicilios: admin lee/escribe/crea, solo el domiciliario asignado puede actualizar estado
    match /domicilios/{domicilioId} {
      allow read: if isAuth() && request.auth.token.admin == true;
      allow create, update: if isAuth() && request.auth.token.admin == true;
      allow update: if isAuth() 
        && resource.data.domiciliarioId == request.auth.uid
        && request.resource.data.estado in ['en_preparacion', 'en_camino', 'entregado'];
      allow delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: inventario (insumos) ============
    // Inventario: solo admin lee/escribe
    match /inventario/{insumoId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: entradas_inventario ============
    // Registro de entradas: solo admin
    match /entradas_inventario/{entradaId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: gastos ============
    // Gastos: solo admin
    match /gastos/{gastoId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: cierres_caja ============
    // Cierres de caja: solo admin
    match /cierres_caja/{cierreId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: configuracion ============
    // Documento bot_config: solo admin lee/escribe
    match /configuracion/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: transacciones_pago (Phase 7) ============
    // Transacciones de pago: solo admin lee/escribe
    // Cloud Functions pueden leer y escribir (sin autenticación)
    match /transacciones_pago/{transaccionId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
      
      // Subcollection: reintentos
      match /reintentos/{reintento} {
        allow read: if isAuth() && request.auth.token.admin == true;
        allow create: if isAuth() && request.auth.token.admin == true;
      }
    }

    // ============ COLECCIÓN: sesiones_pago (Phase 7) ============
    // Sesiones de pago (Stripe/MercadoPago): solo admin lee/escribe
    match /sesiones_pago/{sesionId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ COLECCIÓN: mensajes_whatsapp (Phase 7) ============
    // Mensajes WhatsApp: solo admin lee/escribe
    // Cloud Functions pueden leer y escribir (sin autenticación)
    match /mensajes_whatsapp/{mensajeId} {
      allow read, create, update, delete: if isAuth() && request.auth.token.admin == true;
      
      // Subcollection: eventos de entrega
      match /eventos_entrega/{evento} {
        allow read: if isAuth() && request.auth.token.admin == true;
        allow create: if isAuth() && request.auth.token.admin == true;
      }
    }

    // ============ DEFAULT: DENEGAR TODO ============
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
