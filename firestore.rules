rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isEmployee() {
      return request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.role == 'employee');
    }

    // Productos: menú público para lectura, solo empleados/admin escriben
    match /productos/{productoId} {
      allow read: if true;
      allow create, update, delete: if isEmployee();
    }

    // Combos: menú público para lectura, solo empleados/admin escriben
    match /combos/{comboId} {
      allow read: if true;
      allow create, update, delete: if isEmployee();
    }

    // Ventas: empleados crean y leen, solo admin modifica/elimina
    match /ventas/{ventaId} {
      allow read, create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Domicilios: empleados crean/leen/actualizan, solo admin elimina
    match /domicilios/{domicilioId} {
      allow read, create, update: if isEmployee();
      allow delete: if isAdmin();
    }

    // Inventario: empleados leen/crean, solo admin modifica/elimina
    match /inventario/{insumoId} {
      allow read, create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Entradas de inventario
    match /entradas_inventario/{entradaId} {
      allow read, create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Gastos
    match /gastos/{gastoId} {
      allow read, create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Cierres de caja: solo admin
    match /cierres_caja/{cierreId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Cajas: empleados leen/crean/actualizan, solo admin elimina
    match /cajas/{cajaId} {
      allow read, create, update: if isEmployee();
      allow delete: if isAdmin();
    }

    // Configuración: empleados leen, solo admin escribe
    match /configuracion/{docId} {
      allow read: if isEmployee();
      allow create, update, delete: if isAdmin();
    }

    // Transacciones de pago: solo admin
    match /transacciones_pago/{transaccionId} {
      allow read, create, update, delete: if isAdmin();
      match /reintentos/{reintento} {
        allow read, create: if isAdmin();
      }
    }

    // Sesiones de pago: solo admin
    match /sesiones_pago/{sesionId} {
      allow read, create, update, delete: if isAdmin();
    }

    // Mensajes WhatsApp: solo admin
    match /mensajes_whatsapp/{mensajeId} {
      allow read, create, update, delete: if isAdmin();
      match /eventos_entrega/{evento} {
        allow read, create: if isAdmin();
      }
    }

    // Intentos de PIN: solo Cloud Functions (sin acceso directo desde cliente)
    match /pin_attempts/{uid} {
      allow read, write: if false;
    }

    // Default: denegar todo
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
