rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isEmployee() {
      return request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.role == 'employee');
    }

    match /transferencias/{allPaths=**} {
      allow read: if isEmployee();
      allow create: if isEmployee()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif|jpg)');
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
