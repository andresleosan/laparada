rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: verificar si el usuario está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // ============ CARPETA: transferencias ============
    // Usuarios autenticados pueden subir fotos de transferencia
    match /transferencias/{allPaths=**} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.size < 5 * 1024 * 1024; // Max 5MB
      allow delete: if isAuth() && request.auth.token.admin == true;
    }

    // ============ DEFAULT: Denegar todo ============
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
